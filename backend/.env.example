# ============================================================
# Assistente Comercial 2Solve — variáveis de ambiente
# Copie para .env e preencha. O .env real NUNCA é commitado.
# ============================================================

# --- Banco ---
# SQLite local (padrão). Futuro: postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./assistente.db

# --- Anthropic (cérebro dos agentes) ---
ANTHROPIC_API_KEY=
# Modelo para tarefas rotineiras (triagem, monitor). Confirmar strings em https://docs.claude.com
CLAUDE_MODEL=claude-sonnet-4-6
# Modelo para geração de proposta e análises do advisor
CLAUDE_MODEL_PROPOSAL=claude-opus-4-8

# --- Omie (CRM/ERP) — menor privilégio: só módulos de CRM ---
OMIE_APP_KEY=
OMIE_APP_SECRET=
OMIE_BASE_URL=https://app.omie.com.br/api/v1

# --- Microsoft Graph (app-only / client credentials) ---
# Escopos mínimos: Mail.ReadWrite (triagem + rascunhos), Mail.Send (envio,
# sempre via aprovação) e Calendars.Read.
# Restringir à caixa comercial via Application Access Policy.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Caixa de email comercial monitorada
MS_MAILBOX=comercial@2solve.com

# --- Scheduler ---
# Ligar o APScheduler junto com a API (true em produção)
SCHEDULER_ENABLED=false
# Hora (0-23) da varredura diária de atrasos do monitor_agent
MONITOR_CRON_HOUR=6
# Hora (0-23) da triagem diária da inbox pelo email_agent
EMAIL_TRIAGE_CRON_HOUR=7
